# PostgreSQL connection string.
# Local example:      postgresql://postgres:postgres@localhost:5432/gpa_tracker
# Render example:     postgresql://user:password@dpg-xxxxx.render.com/gpa_tracker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gpa_tracker

# Generate a real one with: openssl rand -hex 32
# Never reuse this placeholder — httpOnly cookies are only as safe as this secret.
SECRET_KEY=change-me-to-a-random-64-character-hex-string

# HS256 is fine for a single-service API like this one.
ALGORITHM=HS256

# How long a login session lasts before the user must sign in again.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of frontend origins allowed to call this API.
# Must be the exact Vercel URL in production — no trailing slash, no wildcard.
CORS_ORIGINS=http://localhost:3000

# Set to "production" on Render so cookies are sent with Secure + SameSite=None.
ENVIRONMENT=development